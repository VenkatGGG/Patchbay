# Patchbay local secret envelope.
# Run `pnpm env:local` to create or backfill apps/web/.env.local.
# Keep real values out of Git.

# LLM provider
PATCHBAY_LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=30000
GEMINI_API_BASE_URL=

# Control plane storage
DATABASE_URL=postgres://patchbay:patchbay@localhost:5432/patchbay
PATCHBAY_STORAGE=postgres

# Operator and agent auth
PATCHBAY_OPERATOR_TOKEN=
PATCHBAY_REQUIRE_ENROLLMENT_TOKEN=true
PATCHBAY_ENROLLMENT_SECRET=
PATCHBAY_REQUIRE_AGENT_TOKEN=true
PATCHBAY_AGENT_AUTH_SECRET=
PATCHBAY_AGENT_TOKEN_TTL_MINUTES=1440
PATCHBAY_TASK_TIMEOUT_SECONDS=300
PATCHBAY_MAX_JSON_BODY_BYTES=1048576
PATCHBAY_ARTIFACT_RETENTION_DAYS=30

# Tailscale automation
TAILSCALE_TAILNET=
TAILSCALE_OAUTH_CLIENT_ID=
TAILSCALE_OAUTH_CLIENT_SECRET=

# Local agent runtime
PATCHBAY_CONTROL_PLANE_URL=http://localhost:3000
PATCHBAY_ENVIRONMENT_ID=env_local
PATCHBAY_AGENT_NAME=local-agent
PATCHBAY_ENROLLMENT_TOKEN=
PATCHBAY_TAILSCALE_UP=false
PATCHBAY_POLL_INTERVAL=5s
