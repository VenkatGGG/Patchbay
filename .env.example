GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
PATCHBAY_LLM_PROVIDER=gemini
DATABASE_URL=postgres://patchbay:patchbay@localhost:5432/patchbay
PATCHBAY_STORAGE=postgres
PATCHBAY_ENROLLMENT_SECRET=change-me-local-secret
PATCHBAY_REQUIRE_ENROLLMENT_TOKEN=false

TAILSCALE_TAILNET=
TAILSCALE_OAUTH_CLIENT_ID=
TAILSCALE_OAUTH_CLIENT_SECRET=

PATCHBAY_CONTROL_PLANE_URL=http://localhost:3000
PATCHBAY_ENVIRONMENT_ID=env_local
PATCHBAY_AGENT_NAME=local-agent
PATCHBAY_POLL_INTERVAL=5s
