{
  "name": "patchbay",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev": "pnpm --filter @patchbay/web dev",
    "web:build": "pnpm --filter @patchbay/web build",
    "web:typecheck": "pnpm --filter @patchbay/web typecheck",
    "db:up": "docker compose up -d postgres",
    "db:local": "node scripts/setup/local-postgres.mjs",
    "db:migrate": "pnpm --filter @patchbay/web db:migrate",
    "agent:test": "go test ./agent/...",
    "agent:build": "mkdir -p agent/bin && go build -trimpath -o agent/bin/patchbay-agent ./agent/cmd/patchbay-agent",
    "agent:run": "go run ./agent/cmd/patchbay-agent",
    "env:local": "node scripts/setup/create-local-env.mjs",
    "test:secrets": "node scripts/checks/secret-guard.mjs",
    "test:env": "node scripts/checks/env-template.mjs",
    "test:env:local": "node scripts/checks/local-env-generator.mjs",
    "test:compose": "node scripts/checks/compose-security.mjs",
    "test:ui": "node scripts/integration/ui-smoke.mjs",
    "test:integration": "node scripts/integration/smoke.mjs",
    "test:integration:postgres": "PATCHBAY_INTEGRATION_STORAGE=postgres node scripts/integration/smoke.mjs",
    "test:task-timeout": "node scripts/integration/task-timeout.mjs",
    "test:llm:fallback": "node scripts/integration/llm-fallback.mjs",
    "test:gemini:live": "node scripts/integration/live-gemini.mjs",
    "test:tailscale:live": "node scripts/integration/live-tailscale.mjs",
    "check": "pnpm test:secrets && pnpm test:env && pnpm test:env:local && pnpm test:compose && pnpm web:typecheck && pnpm web:build && pnpm test:ui && pnpm agent:test && pnpm agent:build && pnpm test:integration && pnpm test:task-timeout && pnpm test:llm:fallback"
  }
}
